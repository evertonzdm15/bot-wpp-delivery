# Variáveis para o deploy em produção (renomeie para .env.production no servidor).
# Lidas pelo deploy.sh e injetadas no docker-stack.yml.

# Imagem (single-node swarm pode usar imagem local construída pelo deploy.sh)
IMAGE=bot-delivery:latest

# Senha do Postgres em produção (TROQUE!)
POSTGRES_PASSWORD=troque-esta-senha

# Evolution API
EVOLUTION_API_URL=https://api.grupodm.site
EVOLUTION_INSTANCE=GRUPODM
EVOLUTION_API_KEY=coloque-sua-api-key-aqui

# URL pública do bot (registra o webhook na Evolution)
PUBLIC_URL=https://bot.grupodm.site

# Telefone do Super Admin (DDI+DDD+numero, só dígitos)
# ATENÇÃO: use um número DIFERENTE da linha do bot (Zap Logística), senão o
# Super Admin não consegue mandar mensagem pro bot (mensagem pra si mesmo é ignorada).
SUPER_ADMIN_PHONE=

# Senha de login do Super Admin (ele digita esse código para entrar)
SUPER_ADMIN_CODE=troque-este-codigo

# Código de teste que libera os 4 perfis a QUALQUER número.
# DEIXE VAZIO em produção (senão é uma brecha de segurança).
BOT_TEST_CODE=

# Token opcional para proteger o webhook (?token=...)
WEBHOOK_TOKEN=
