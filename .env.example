# Servidor
PORT=3000
NODE_ENV=development
TZ=America/Sao_Paulo
LOG_LEVEL=info

# Banco de dados
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/botdelivery?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Evolution API
EVOLUTION_API_URL=https://api.grupodm.site
EVOLUTION_INSTANCE=GRUPODM
EVOLUTION_API_KEY=coloque-sua-api-key-aqui

# URL pública deste bot (usada para auto-registrar o webhook na Evolution)
# Ex.: https://bot.grupodm.site  ou  uma URL de túnel (ngrok) em dev
PUBLIC_URL=

# Token opcional para proteger o webhook (?token=...)
WEBHOOK_TOKEN=

# Telefone do Super Admin (somente dígitos, com DDI: 55DDDNUMERO)
SUPER_ADMIN_PHONE=5541996789580

# SLAs em minutos (prazo a partir da criação)
SLA_RAPIDA_R6_MIN=40
SLA_RAPIDA_MIN=90

# Antecedência do alerta de vencimento (minutos)
ALERTA_ANTECEDENCIA_MIN=15
